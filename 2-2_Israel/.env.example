# Provedor de LLM: ollama, gemini ou openai.
PROVEDOR_LLM=ollama

# Modelo correspondente ao provedor selecionado.
# Exemplos: qwen3:4b (Ollama), gemini-2.5-flash (Gemini), gpt-4o-mini (OpenAI).
MODELO_LLM=qwen3:4b

# URL do Ollama. No Docker, use host.docker.internal para acessar o host.
OLLAMA_URL=http://host.docker.internal:11434

# Obrigatória para Gemini e OpenAI; deixe vazia ao usar Ollama local.
CHAVE_DA_API=

# Tempo máximo, em segundos, para uma inferência antes do fallback.
TEMPO_LIMITE_INFERENCIA=5
